# Database (you'll need to set up a PostgreSQL database - Vercel Postgres or Neon)
DATABASE_URL="postgresql://user:password@host:5432/saas_sites?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# AI Service
OPENAI_API_KEY="sk-your-openai-key-here"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# For production on Vercel, set these in Vercel dashboard
# VERCEL_URL will be automatically set by Vercel
