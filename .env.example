# Database
DATABASE_URL="postgresql://user:password@localhost:5432/saas_sites?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# AI Service (for dynamic site generation)
OPENAI_API_KEY="sk-your-openai-key"

# Gemini API (for HTML refinement and content generation)
GEMINI_API_KEY="your-gemini-api-key"

# YouTube API (for niche research pipeline)
YOUTUBE_API_KEY="your-youtube-api-key"

# Stitch (Google) API (for initial template generation)
STITCH_API_KEY="your-stitch-api-key"

# Context.dev / Brand.dev API (brand enrichment: logo, colors, socials from domain)
# https://docs.context.dev/api-reference/brand-intelligence/retrieve-brand-data-by-domain
CONTEXT_DEV_API_KEY="your-context-dev-api-key"

# FormForge API (optional — free tier works without key, 20 forms/day)
# https://formforge-api.vercel.app/docs
# FORMFORGE_API_KEY="ff_live_your_key"

# SECURITY: Add ALL API keys below as Environment Variables in Vercel Dashboard
# https://vercel.com/gerador-site-teste/settings/environment-variables
# DO NOT commit any .env* files with real keys — use Vercel's UI or `vercel env add`
#
# Required vars to add in Vercel:
#   DATABASE_URL, NEXTAUTH_SECRET, OPENAI_API_KEY, GEMINI_API_KEY,
#   YOUTUBE_API_KEY, STITCH_API_KEY, CONTEXT_DEV_API_KEY

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
