generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BusinessType {
  // Food & Beverage
  RESTAURANT
  BAR
  PIZZERIA
  SUSHI
  ROTISSERIE
  BURGER_JOINT
  STEAKHOUSE
  SEAFOOD
  VEGAN
  ICE_CREAM
  BAKERY
  CONFECTIONERY
  CAFE
  BREWERY
  
  // Services
  BARBERSHOP
  SALON
  SPA
  GYM
  YOGA_STUDIO
  DANCE_STUDIO
  
  // Retail & Shops
  RETAIL
  PET_SHOP
  BOOKSTORE
  FLORIST
  TOY_STORE
  ELECTRONICS
  CLOTHING
  JEWELRY
  ART_GALLERY
  SPORTS_STORE
   
  // Health & Wellness
  PHARMACY
  CLINIC
  DENTIST
  OPTICS
  NUTRITIONIST
  
  // Home & Services
  CLEANING_SERVICE
  PLUMBING
  ELECTRICIAN
  LANDSCAPING
  MOVING
  
  // Automotive
  AUTOMOTIVE
  CAR_WASH
  TIRE_SHOP
  DETAILING
  
  // Other
  TRAVEL_AGENCY
  REAL_ESTATE
  EVENT_PLANNER
  PHOTOGRAPHER
  HOTEL
  OTHER
  
  // Technology & Professional Services
  TECH
  LAWYER
  CONSULTING
  EDUCATION
  FITNESS
  COFFEE
  NIGHTCLUB
  EVENTS
  DESIGN
  AGENCY
  FREELANCER
  STARTUP
  ECOMMERCE
  MARKETPLACE
  SAAS
  APP
  SOFTWARE
  FINANCIAL
  INSURANCE
  ACCOUNTING
  INVESTMENT
  ARCHITECTURE
  INTERIOR_DESIGN
  CONSTRUCTION
  TRAVEL
  BEAUTY
  FASHION
  ART
  MUSIC
  NONPROFIT
}

enum TemplateStyle {
  CATALOG
  PORTFOLIO
  LANDING
  BOOKING
  ECOMMERCE
  BLOG
}

model Business {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  type        BusinessType
  description String?
  address     String?
  phone       String?
  email       String?
  logo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sites Site[]
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])
  @@index([slug])
  @@index([type])
}

model Site {
  id            String        @id @default(cuid())
  businessId    String
  business      Business      @relation(fields: [businessId], references: [id])
  templateStyle TemplateStyle
  title         String
  metaDescription String?
  content       Json?
  customCss     String?
  published     Boolean       @default(false)
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  @@index([businessId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  businesses   Business[]
  plan          String    @default("simple")
  planExpires  DateTime? // When the monthly plan expires
  sitesUsed     Int       @default(0)
  sitesLimit    Int       @default(5) // Simple = 5, Premium = unlimited(-1)
  planFeatures  Json?     // Store plan-specific features/methods
  @@index([email])
}

model Template {
  id          String        @id @default(cuid())
  businessType BusinessType
  style       TemplateStyle
  name        String
  description String?
  thumbnail   String?
  config      Json?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  @@index([businessType, style])
}

model Lead {
  id          String    @id @default(cuid())
  siteId      String
  name        String?
  email       String?
  phone      String?
  message    String?
  source     String?   // whatsapp, form, email
  status     String    @default("new") // new, contacted, converted, lost
  createdAt  DateTime  @default(now())
  @@index([siteId])
  @@index([status])
}

model Analytics {
  id          String    @id @default(cuid())
  siteId      String
  page       String
  visitors   Int       @default(0)
  uniqueVisitors Int    @default(0)
  bounces    Int       @default(0)
  avgTime    Int       @default(0)
  createdAt  DateTime  @default(now())
  date       DateTime  @default(now()) @db.Date
  @@unique([siteId, page, date])
}