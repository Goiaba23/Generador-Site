// Prisma schema for SaaS Sites Platform
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum for business types - 30+ types for comprehensive coverage
enum BusinessType {
  // Food & Beverage
  RESTAURANT
  BAR
  PIZZERIA
  SUSHI
  ROTISSERIE
  BURGER_JOINT
  STEAKHOUSE
  SEAFOOD
  VEGAN
  ICE_CREAM
  BAKERY
  CONFECTIONERY
  CAFE
  BREWERY
  
  // Services
  BARBERSHOP
  SALON
  SPA
  GYM
  YOGA_STUDIO
  DANCE_STUDIO
  
  // Retail & Shops
  RETAIL
  PET_SHOP
  BOOKSTORE
  FLORIST
  TOY_STORE
  ELECTRONICS
  CLOTHING
  JEWELRY
  ART_GALLERY
  SPORTS_STORE
  
  // Health & Wellness
  PHARMACY
  CLINIC
  DENTIST
  OPTICS
  NUTRITIONIST
  
  // Home & Services
  CLEANING_SERVICE
  PLUMBING
  ELECTRICIAN
  LANDSCAPING
  MOVING
  
  // Automotive
  AUTOMOTIVE
  CAR_WASH
  TIRE_SHOP
  DETAILING
  
  // Other
  TRAVEL_AGENCY
  REAL_ESTATE
  EVENT_PLANNER
  PHOTOGRAPHER
  HOTEL
  OTHER
}

// Enum for site templates
enum TemplateStyle {
  CATALOG
  PORTFOLIO
  LANDING
  BOOKING
  ECOMMERCE
  BLOG
}

// Business/Company model
model Business {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique // for subdomain: burger-queen.saas-sites.com
  type        BusinessType
  description String?
  address     String?
  phone       String?
  email       String?
  logo        String? // URL to logo image
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relation to generated sites
  sites Site[]
  // Owner of this business
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  @@index([slug])
  @@index([type])
}

// Generated sites
model Site {
  id            String        @id @default(cuid())
  businessId    String
  business      Business      @relation(fields: [businessId], references: [id])
  templateStyle TemplateStyle
  title         String
  metaDescription String?
  content       Json? // stores the generated site content (components, layout, etc.)
  customCss     String? // any custom CSS overrides
  published     Boolean       @default(false)
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([businessId])
}

// User model (for authentication)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String? // hashed
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  businesses Business[] // businesses owned by this user

  @@index([email])
}

// Template presets for each business type
model Template {
  id          String        @id @default(cuid())
  businessType BusinessType
  style       TemplateStyle
  name        String
  description String?
  thumbnail   String? // preview image URL
  config      Json? // default configuration for this template
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  @@index([businessType, style])
}
